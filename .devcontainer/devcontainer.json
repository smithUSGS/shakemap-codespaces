{
  "name": "ShakeMap Workshop",
 
  "build": { "dockerfile": "Dockerfile" },
 
  "hostRequirements": { "cpus": 2 },
 
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
 
  "remoteUser": "vscode",
 
  "postCreateCommand": "echo 'Codespace ready. Next: cd ~/shakemap-src && bash install.sh'"
}
