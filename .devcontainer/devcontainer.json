{
  "name": "ShakeMap Workshop (v4.4.9)",
 
  "build": {
    "dockerfile": "Dockerfile.workshop",
    "args": { "SHAKEMAP_VERSION": "v4.4.9" }
  },
 
  // 2-core is plenty for ShakeMap; bump to 4 if you expect heavy simultaneous runs.
  "hostRequirements": { "cpus": 2 },
 
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
 
  "remoteUser": "vscode",
 
  "postCreateCommand": "bash -lc 'conda activate shakemap && shake -v && echo \"ShakeMap ready — try: sm_profile -l\"'"
}
